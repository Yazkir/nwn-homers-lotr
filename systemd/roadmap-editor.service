[Unit]
# Local web GUI for editing roadmap.yaml (the dev-roadmap / merit-tracking
# backlog). A user service so it runs as James and binds localhost only.
# Always-on so the editor is a bookmark (http://localhost:8765) rather than a
# command to remember. Install:
#   systemctl --user enable --now roadmap-editor.service
#   loginctl enable-linger james     # so it starts at boot, before login
Description=Homer's LotR roadmap.yaml web editor (localhost:8765)
Documentation=file:///var/home/james/GIT/nwn_homers_lotr/CLAUDE-roadmap.md
After=default.target

[Service]
Type=simple
WorkingDirectory=/var/home/james/GIT/nwn_homers_lotr
ExecStart=/usr/bin/python3 /var/home/james/GIT/nwn_homers_lotr/bin/roadmap-editor.py --serve --port 8765
Restart=on-failure
RestartSec=5
Nice=10

[Install]
WantedBy=default.target
