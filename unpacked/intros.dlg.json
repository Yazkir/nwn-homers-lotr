        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "I am here to tell you about the updates and guidelines of the Lord of the Rings. What would you like to talk about?"
          }
        }
      },
      {
        "__struct_id": 1,
        "Animation": {
          "type": "dword",
