        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "Player names can not be any major character names from any book written by Tolkien. These names are reserved for the module NPC's. If you have taken a name from the books your character will be deleted with the next reset."
          }
        }
      },
      {
        "__struct_id": 2,
        "Animation": {
          "type": "dword",
