// TRUE when oItem matches a known legally-placed variant. Only consulted
// for items already over the legal caps and deviating from blueprint, so
// a linear chunk scan is cheap enough.
int ForgeIsKnownLegalVariant(object oItem)
{
    string sFP = ForgeLegalFingerprint(oItem);
    if (ForgeLegalChunk0(sFP)) return TRUE;
    if (ForgeLegalChunk1(sFP)) return TRUE;
    if (ForgeLegalChunk2(sFP)) return TRUE;
    if (ForgeLegalChunk3(sFP)) return TRUE;
    return FALSE;
}
