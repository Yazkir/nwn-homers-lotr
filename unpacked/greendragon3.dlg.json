          "value": ""
        },
        "Speaker": {
          "type": "cexostring",
          "value": ""
        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "He has poisoned our guests, made rats come around the Inn, and last night they did something which crossed the line and made us sure it was them. They attacked one of our Inn Keepers and cut his arm. We are hoping he will survive, but this calls for drastic measures."
          }
        }
      },
      {
        "__struct_id": 11,
        "Animation": {
          "type": "dword",
          "value": 0
        },
        "AnimLoop": {
          "type": "byte",
