          "value": ""
        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "Ah. So I see! You must be some fella when you gained HIS trust. Well you got mine too then."
          }
        }
      },
      {
        "__struct_id": 8,
        "Animation": {
          "type": "dword",
          "value": 0
        },
        "AnimLoop": {
