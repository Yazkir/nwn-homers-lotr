        },
        "Speaker": {
          "type": "cexostring",
          "value": ""
        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "He knows that if any rumored evil becomes powerful in the east, we will spread the news and collect support for fighting him. No one sane wants him to rule Shire and Hobbitton, but perhaps maybe of his henchmen."
          }
        }
      },
      {
        "__struct_id": 10,
        "Animation": {
          "type": "dword",
          "value": 0
        },
        "AnimLoop": {
          "type": "byte",
          "value": 1
        },
        "Comment": {
          "type": "cexostring",
