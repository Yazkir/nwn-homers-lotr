      {
        "__struct_id": 11,
        "Comment": {
          "type": "cexostring",
          "value": "MeaningWave meta-quest. Stage 1 added on first module entry; stages 2-8 tick per guide unlock; stage 9 ends at Akira's finale."
        },
        "Name": {
          "type": "cexolocstring",
          "value": {
            "0": "The Path of Meaning"
          }
        },
        "Picture": {
          "type": "word",
          "value": 65535
        },
        "Priority": {
          "type": "dword",
          "value": 2
        },
        "Tag": {
          "type": "cexostring",
          "value": "MW Path of Meaning"
        },
        "XP": {
          "type": "dword",
          "value": 2000
        },
        "EntryList": {
          "type": "list",
          "value": [
            {
              "__struct_id": 0,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 1
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "A strange music whispers across Middle-earth \u2014 fragments of wisdom carried on a beat that should not exist here. Seven legends are scattered across the world. Find them, prove yourself, and the Hall of Legends will open to you."
                }
              }
            },
            {
              "__struct_id": 1,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 2
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "One legend recognises me. Six remain."
                }
              }
            },
            {
              "__struct_id": 2,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 3
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "Two of the seven walk beside me now in spirit. Five remain."
                }
              }
            },
            {
              "__struct_id": 3,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 4
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "Three legends have shared their wisdom. Four remain."
                }
              }
            },
            {
              "__struct_id": 4,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 5
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "Four legends. The music grows clearer."
                }
              }
            },
            {
              "__struct_id": 5,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 6
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "Five legends gathered. Two voices still hidden."
                }
              }
            },
            {
              "__struct_id": 6,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 7
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "Six legends recognise me. One voice remains."
                }
              }
            },
            {
              "__struct_id": 7,
              "End": {
                "type": "word",
