              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "Travel to the Ruins of Dale and retrieve the heirloom stolen from Gloisin."
                }
              }
            },
            {
              "__struct_id": 1,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 2
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "You were well rewarded for your return of Gloisin's heirloom.  Adventuring does have its advantages."
                }
              }
