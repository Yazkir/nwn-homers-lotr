        },
        "EntryList": {
          "type": "list",
          "value": [
            {
              "__struct_id": 0,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 1
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "A man named Bill Ferny has lost a ring to an underling who was chased into a nearby cave. I agreed to go search the cave and return the ring. Although Ferny sure does seem the shifty type."
                }
              }
            },
            {
              "__struct_id": 1,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 2
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "I brought back Ferny's Ring. Although I am concerned by the enscription.\"Servant of Sharkey\" doesn't sound to appealing. Well I best go collect my reward and then maybe see what I can find out about this Sharkey character."
                }
              }
            },
            {
              "__struct_id": 2,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 3
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "An ambush awaited me in Ferny's Hole of a house. I kept the letter in the hopes of finding someone who can tell me more about it."
                }
              }
            },
            {
              "__struct_id": 3,
              "End": {
                "type": "word",
                "value": 0
              },
              "ID": {
                "type": "dword",
                "value": 4
              },
              "Text": {
                "type": "cexolocstring",
                "value": {
                  "0": "An Ambush awaited me in Ferny's Hole of a house. I gave Ferny back his stupid letter, and i shall keep my eye out for more Servants of Sharkey."
                }
              }
            }
          ]
        },
        "Name": {
          "type": "cexolocstring",
