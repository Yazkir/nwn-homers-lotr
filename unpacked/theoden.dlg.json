        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "My trusted friend Worm Tongue has left for Isengard. But I fear he may never come back."
          }
        }
      },
      {
        "__struct_id": 3,
        "Animation": {
          "type": "dword",
          "value": 0
        },
        "AnimLoop": {
