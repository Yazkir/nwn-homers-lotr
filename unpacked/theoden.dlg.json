        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "My heart warms to hear this. Perhaps it is not as dark a day as I had imagined. There is one there who is their leader. They call him, The White Hand Destroyer. Bring me his weapon of choice and I will consider the blockade broken!"
          }
        }
