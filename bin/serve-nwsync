#!/usr/bin/env bash
# serve-nwsync — run the nginx container that hosts the NWSync repository
# for connecting EE clients.
#
# Idempotent: safe to call from bin/serve on every server start. If the
# container is already healthy on the configured port, exits 0 without
# touching it. Otherwise (re)creates it detached.
#
# Stop manually with: podman stop -t 4 nwnsync-nginx

set -euo pipefail

PROJECT_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
ENV_FILE="$PROJECT_ROOT/server.env"
LOCAL_ENV_FILE="$PROJECT_ROOT/server.env.local"

# shellcheck disable=SC1090
. "$ENV_FILE"
[[ -f $LOCAL_ENV_FILE ]] && . "$LOCAL_ENV_FILE"

: "${NWNSYNC_REPO:?server.env must define NWNSYNC_REPO}"
: "${NWNSYNC_PORT:?server.env must define NWNSYNC_PORT}"
: "${NWNSYNC_CONTAINER:=nwnsync-nginx}"
: "${NWNSYNC_IMAGE:=docker.io/nginx:alpine}"

if [[ ! -d $NWNSYNC_REPO ]]; then
  echo "[nwsync] repo dir does not exist: $NWNSYNC_REPO" >&2
  echo "[nwsync] run bin/refresh-nwsync first" >&2
  exit 1
fi

if [[ ! -f "$NWNSYNC_REPO/latest" ]]; then
  echo "[nwsync] warning: $NWNSYNC_REPO has no /latest manifest pointer." >&2
  echo "[nwsync]          run bin/refresh-nwsync to populate it." >&2
fi

# If a container with this name is already running and looks healthy, leave it.
if podman container exists "$NWNSYNC_CONTAINER" 2>/dev/null; then
  state=$(podman inspect -f '{{.State.Status}}' "$NWNSYNC_CONTAINER" 2>/dev/null || echo missing)
  if [[ $state == running ]]; then
    echo "[nwsync] $NWNSYNC_CONTAINER already running on :$NWNSYNC_PORT — leaving it"
    exit 0
  fi
  echo "[nwsync] removing stale container ($state)"
  podman rm -f "$NWNSYNC_CONTAINER" >/dev/null 2>&1 || true
fi

echo "[nwsync] starting $NWNSYNC_CONTAINER on :$NWNSYNC_PORT  →  $NWNSYNC_REPO"

# autoindex is on so a manual `curl http://host:PORT/manifests/` returns
# something human-readable; nwsync clients fetch fixed paths and don't need it.
nginx_conf=$(mktemp)
trap 'rm -f "$nginx_conf"' EXIT
cat > "$nginx_conf" <<'EOF'
server {
  listen       80 default_server;
  server_name  _;
  root         /usr/share/nginx/html;
  autoindex    on;
  # nwsync blobs are content-addressed and immutable; cache hard.
  location / {
    add_header Cache-Control "public, max-age=31536000, immutable";
    try_files $uri $uri/ =404;
  }
  # /latest is the only mutable file — must always be revalidated.
  location = /latest {
    add_header Cache-Control "no-cache";
  }
}
EOF

podman run -d --rm --name "$NWNSYNC_CONTAINER" \
  -p "${NWNSYNC_PORT}:80" \
  -v "$NWNSYNC_REPO:/usr/share/nginx/html:ro,z" \
  -v "$nginx_conf:/etc/nginx/conf.d/default.conf:ro,z" \
  "$NWNSYNC_IMAGE" >/dev/null

# Brief confirmation that the listener actually came up.
for _ in 1 2 3 4 5; do
  if curl -sSf -o /dev/null "http://127.0.0.1:${NWNSYNC_PORT}/" 2>/dev/null; then
    echo "[nwsync] up at http://127.0.0.1:${NWNSYNC_PORT}/"
    exit 0
  fi
  sleep 0.5
done

echo "[nwsync] warning: container started but :${NWNSYNC_PORT} did not respond within 2.5s" >&2
echo "[nwsync] check: podman logs $NWNSYNC_CONTAINER" >&2
exit 0
