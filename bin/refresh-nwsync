#!/usr/bin/env bash
# refresh-nwsync — rebuild the NWSync manifest for Homer's LOTR VEL v3.
#
# Reads ../server.env for NWNSYNC_REPO and NWN_HOME_DIR, then invokes
# nwn_nwsync_write so connecting EE clients auto-download CEP haks + the
# cep.tlk instead of needing them pre-installed.
#
# Run this after every repack (the repack shortcut chains it automatically),
# or directly via the "Refresh Homer's LotR NWSync" app-grid shortcut.

set -euo pipefail

PROJECT_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
ENV_FILE="$PROJECT_ROOT/server.env"
LOCAL_ENV_FILE="$PROJECT_ROOT/server.env.local"

# shellcheck disable=SC1090
. "$ENV_FILE"
[[ -f $LOCAL_ENV_FILE ]] && . "$LOCAL_ENV_FILE"

: "${NWN_HOME_DIR:?server.env must define NWN_HOME_DIR}"
: "${NWN_MODULE:?server.env must define NWN_MODULE}"
: "${NWNSYNC_REPO:?server.env must define NWNSYNC_REPO}"

NWN_NWSYNC_WRITE="${NWN_NWSYNC_WRITE:-$HOME/.nimble/bin/nwn_nwsync_write}"
if [[ ! -x $NWN_NWSYNC_WRITE ]]; then
  echo "error: nwn_nwsync_write not found at $NWN_NWSYNC_WRITE" >&2
  echo "       install niv/neverwinter.nim or set NWN_NWSYNC_WRITE in server.env.local" >&2
  exit 1
fi

MOD_FILE="$NWN_HOME_DIR/modules/${NWN_MODULE}.mod"
if [[ ! -f $MOD_FILE ]]; then
  echo "error: module not found: $MOD_FILE" >&2
  echo "       run the repack shortcut first" >&2
  exit 1
fi

mkdir -p "$NWNSYNC_REPO"

echo "[nwsync] repo:    $NWNSYNC_REPO"
echo "[nwsync] module:  $MOD_FILE"
echo "[nwsync] hak dir: $NWN_HOME_DIR/hak"
echo "[nwsync] tlk dir: $NWN_HOME_DIR/tlk"
echo

# No --with-module: this is a persistent world, clients don't need the .mod
# itself, only the haks + tlk it references. nwn_nwsync_write reads the .mod
# to discover its dependency list and pulls them from --path dirs.
manifest_name="${NWN_SERVERNAME:-Homers LOTR VEL v3}"

"$NWN_NWSYNC_WRITE" \
  --name "$manifest_name" \
  --description "Homers LotR VEL v3 — CEP 2 content pack" \
  --path "$NWN_HOME_DIR/hak" \
  --path "$NWN_HOME_DIR/tlk" \
  -f \
  "$NWNSYNC_REPO" \
  "$MOD_FILE"

echo
if [[ -f "$NWNSYNC_REPO/latest" ]]; then
  hash=$(cat "$NWNSYNC_REPO/latest")
  echo "[nwsync] latest manifest: $hash"
  url="${NWNSYNC_PUBLIC_URL:-}"
  if [[ -n $url ]]; then
    echo "[nwsync] clients will fetch from: ${url}/manifests/$hash"
  else
    echo "[nwsync] (set NWNSYNC_PUBLIC_URL in server.env.local to advertise to clients)"
  fi
fi
