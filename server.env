# Homer's LOTR VEL v3 — dedicated server config.
#
# Sourced by bin/serve. Edit values here, not in the launcher script.
# All NWNX:EE plugins skip by default; flip to "n" to enable.

# ---------------------------------------------------------------- container --
NWN_IMAGE="docker.io/nwnxee/unified:latest"
NWN_CONTAINER_NAME="nwnxee-homer"

# Persistent runtime dir on the host. Survives reboots; container's /nwn/run
# is bind-mounted here so logs, the SQLite campaign DB, NWSync state, etc.
# all live in this directory and are inspectable from the host.
NWN_RUN_DIR="$HOME/.local/state/nwnxee-homer"

# Where the server reads modules / haks / tlk / servervault from.
NWN_HOME_DIR="$HOME/.local/share/Neverwinter Nights"

# ---------------------------------------------------------------- gameplay ---
NWN_MODULE="Homer's LOTR VEL v3"
NWN_SERVERNAME="Homer's LOTR Very Easy Leveling"
NWN_PORT=5121
NWN_MAXCLIENTS=30
NWN_PUBLICSERVER=1       # 1 to advertise on the master server
NWN_SERVERVAULT=1        # required for HGLL persistence (see CLAUDE.md L5)
NWN_DIFFICULTY=3
NWN_PVP=2
NWN_AUTOSAVEINTERVAL=0  # minutes; 0 disables
NWN_ELC=0
NWN_ILR=0
NWN_PAUSE_AND_PLAY=0

#Passwords (Set these in server.env.local instead -- not committed to GIT)
#NWN_PLAYERPASSWORD=""
#NWN_DMPASSWORD=""
#NWN_ADMINPASSWORD=""

# ---------------------------------------------------------------- NWNX -------
# These match the plugin set HGLL needs after the Letoscript port:
#   Creature, Player, Object, Administration, Util, Events, MaxLevel.
# Core + ServerLogRedirector are always on.
NWNX_CREATURE_SKIP=n
NWNX_ADMINISTRATION_SKIP=n
NWNX_PLAYER_SKIP=n
NWNX_OBJECT_SKIP=n
NWNX_UTIL_SKIP=n
NWNX_EVENTS_SKIP=n
NWNX_MAXLEVEL_SKIP=n
NWNX_MAXLEVEL_MAX=60

# ---------------------------------------------------------------- NWSync -----
# bin/refresh-nwsync writes the manifest into NWNSYNC_REPO; bin/serve-nwsync
# runs an nginx container that serves it on NWNSYNC_PORT. nwserver itself
# only *advertises* NWNSYNC_PUBLIC_URL — clients fetch the bytes from nginx.
NWNSYNC_REPO="$HOME/OneDrive/Games/NWNsync-HomersLOTR"
NWNSYNC_PORT=8000
NWNSYNC_CONTAINER="nwnsync-nginx"
NWNSYNC_IMAGE="docker.io/nginx:alpine"

# Public URL the master server hands to clients. Must be reachable from the
# *internet*, not just LAN — set in server.env.local with your WAN IP or
# DDNS hostname, e.g. "http://homer.example.com:8000". Leave unset to skip
# nwsync advertisement (clients then need CEP installed locally to join).
#NWNSYNC_PUBLIC_URL=""

# Forwarded into the nwnxee container so the game server announces the URL.
NWN_NWSYNCURL="${NWNSYNC_PUBLIC_URL:-}"
NWN_NWSYNCPUBLISHHAKS=0  # nginx serves the bytes; nwserver only advertises
