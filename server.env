# Homer's LOTR VEL v3 — dedicated server config.
#
# Sourced by bin/serve. Edit values here, not in the launcher script.
# All NWNX:EE plugins skip by default; flip to "n" to enable.

# ---------------------------------------------------------------- container --
# Anvil image = nwnxee/unified + bundled Anvil .NET host + NWNX_DotNET preconfigured.
# Tag matches our NWN build (8193.37) and the pinned NWN.Anvil NuGet (8193.37.3).
# The Dungeon Solitaire C# plugin (csharp/) needs this; the plain nwnxee/unified
# image does NOT ship Anvil, so the plugin silently never loads. To run without
# the C# plugin, swap back to "docker.io/nwnxee/unified:latest".
NWN_IMAGE="docker.io/nwndotnet/anvil:8193.37.3"
NWN_CONTAINER_NAME="nwnxee-homer"
TZ=America/Chicago

# Persistent runtime dir on the host. Survives reboots; container's /nwn/run
# is bind-mounted here so logs, the SQLite campaign DB, NWSync state, etc.
# all live in this directory and are inspectable from the host.
NWN_RUN_DIR="$HOME/.local/state/nwnxee-homer"

# Where the server reads modules / haks / tlk / servervault from.
NWN_HOME_DIR="$HOME/.local/share/Neverwinter Nights"

# ---------------------------------------------------------------- gameplay ---
NWN_MODULE="Homer's LOTR VEL v3"
NWN_SERVERNAME="Homer's LOTR Very Easy Leveling"
NWN_PORT=5121
NWN_MAXCLIENTS=30
NWN_PUBLICSERVER=1       # 1 to advertise on the master server
NWN_SERVERVAULT=1        # required for HGLL persistence (see CLAUDE.md L5)
NWN_DIFFICULTY=3
NWN_PVP=2
NWN_AUTOSAVEINTERVAL=0  # minutes; 0 disables
NWN_ELC=0
NWN_ILR=0
NWN_PAUSEANDPLAY=0
NWN_MAXHP=1             # always roll max HP on level up
NWN_STICKYMODES=1       # combat modes persist between combats
NWN_MAX_ABILITY_BONUS=24  # raised from default 12; patched into settings.tml by bin/serve

#Passwords (Set these in server.env.local instead -- not committed to GIT)
#NWN_PLAYERPASSWORD=""
#NWN_DMPASSWORD=""
#NWN_ADMINPASSWORD=""

# ---------------------------------------------------------------- NWNX -------
# These match the plugin set HGLL needs after the Letoscript port:
#   Creature, Player, Object, Administration, Util, Events, MaxLevel.
# Core + ServerLogRedirector are always on.
NWNX_CREATURE_SKIP=n
NWNX_ADMINISTRATION_SKIP=n
NWNX_PLAYER_SKIP=n
NWNX_OBJECT_SKIP=n
NWNX_UTIL_SKIP=n
NWNX_EVENTS_SKIP=n
NWNX_MAXLEVEL_SKIP=y
NWNX_TWEAKS_SKIP=n
NWNX_TWEAKS_CHARLIST_SORT_BY_LAST_PLAYED_DATE=true
NWNX_TWEAKS_CAN_USE_ITEMS_WHILE_POLYMORPHED=true

# .NET host for the Anvil plugin (Dungeon Solitaire, csharp/). Required — the
# default SKIP_ALL config would otherwise skip NWNX_DotNET and Anvil never boots.
# ANVIL_LOG_MODE=Redirect surfaces Anvil's log (look for "[DungeonSolitaire]
# wired ... lever") in logs.0/ and `podman logs nwnxee-homer`.
NWNX_DOTNET_SKIP=n
ANVIL_LOG_MODE=Redirect

# Daily scheduled-restart time (server-local HH:mm), read by the Anvil
# ServerRestartManager plugin. It broadcasts countdown warnings (60/30/15/10/5/1
# min), exports all characters, and shuts the server down at this time. The host
# root systemd timer (nwn-reboot.timer) reboots the machine a few minutes later;
# the server auto-starts on boot. Leave empty to disable in-game scheduling.
ANVIL_RESTART_DAILY=11:30

# Extra nwserver CLI args. -userdirectory is required (image default); -maxhp
# forces max HP on every level-up. Sticky combat modes has no CLI flag — see
# onmoduleload.nss for the NWNX_Administration approach if needed.
NWN_EXTRA_ARGS="-userdirectory /nwn/run"

# ---------------------------------------------------------------- NWSync -----
# bin/refresh-nwsync writes the manifest into NWNSYNC_REPO; bin/serve-nwsync
# runs an nginx container that serves it on NWNSYNC_PORT. nwserver itself
# only *advertises* NWNSYNC_PUBLIC_URL — clients fetch the bytes from nginx.
NWNSYNC_REPO="$HOME/.local/share/Neverwinter Nights/nwsync/HomersLOTR"
NWNSYNC_PORT=8000
NWNSYNC_CONTAINER="nwnsync-nginx"
NWNSYNC_IMAGE="docker.io/nginx:alpine"

# Public URL the master server hands to clients. Must be reachable from the
# *internet*, not just LAN — set in server.env.local with your WAN IP or
# DDNS hostname, e.g. "http://homer.example.com:8000". Leave unset to skip
# nwsync advertisement (clients then need CEP installed locally to join).
#NWNSYNC_PUBLIC_URL=""

# Forwarded into the nwnxee container so the game server announces the URL.
NWN_NWSYNCURL="${NWNSYNC_PUBLIC_URL:-}"
NWN_NWSYNCPUBLISHHAKS=0  # nginx serves the bytes; nwserver only advertises
